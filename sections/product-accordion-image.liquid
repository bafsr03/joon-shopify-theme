{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
    background-color: #fafafa; /* Consistent light theme */
    color: #111111;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }

  .accordion-image-container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 2rem;
    display: flex;
    flex-direction: column;
    gap: 40px;
    align-items: center;
  }

  @media screen and (min-width: 900px) {
    .accordion-image-container {
      flex-direction: row;
      justify-content: space-between;
      gap: 60px;
    }
  }

  .accordion-content {
    flex: 1;
    width: 100%;
    max-width: 500px;
  }

  .accordion-title {
    font-size: 2.5rem;
    line-height: 1.2;
    margin-bottom: 2rem;
    text-align: center;
    font-family: var(--font-heading-family);
  }
  @media screen and (min-width: 900px) {
    .accordion-title {
      text-align: left;
    }
  }

  .accordion-list {
    display: flex;
    flex-direction: column;
  }

  .accordion-item {
    border-bottom: 1px solid #ddd;
    padding: 16px 0;
  }
  .accordion-item:first-child {
    border-top: 1px solid #ddd;
  }

  .accordion-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    cursor: pointer;
    font-weight: bold;
    font-size: 0.9rem;
    letter-spacing: 1px;
    text-transform: uppercase;
    color: #444;
    transition: color 0.3s ease;
  }
  .accordion-header:hover {
    color: #32402C;
  }
  
  .accordion-icon {
    font-size: 1.2rem;
    color: #444;
    transition: transform 0.3s ease;
  }

  .accordion-body {
    max-height: 0;
    overflow: hidden;
    transition: max-height 0.3s ease;
    font-size: 0.9rem;
    color: #666;
    line-height: 1.5;
  }

  .accordion-item.active .accordion-icon {
    transform: rotate(45deg); /* + turns into x */
    color: #32402C;
  }
  .accordion-item.active .accordion-header {
    color: #111111;
  }
  .accordion-item.active .accordion-body {
    max-height: 200px; /* Arbitrary large height to allow content */
    padding-top: 12px;
  }

  .accordion-image-wrapper {
    flex: 1;
    width: 100%;
    max-width: 600px;
    display: flex;
    justify-content: center;
  }

  .accordion-image-wrapper img {
    width: 100%;
    height: auto;
    object-fit: cover;
    border-radius: 8px; /* Optional subtle rounding */
  }
{%- endstyle -%}

<div class="section-{{ section.id }}-padding">
  <div class="accordion-image-container">
    
    <!-- Left: Accordion content -->
    <div class="accordion-content">
      {% if section.settings.title != blank %}
        <h2 class="accordion-title">{{ section.settings.title }}</h2>
      {% endif %}

      <div class="accordion-list">
        {% for block in section.blocks %}
          <div class="accordion-item {% if forloop.first %}active{% endif %}" onclick="this.classList.toggle('active')">
            <div class="accordion-header">
              {{ block.settings.heading | default: "Accordion Item" }}
              <span class="accordion-icon">+</span>
            </div>
            <div class="accordion-body">
              {{ block.settings.content | default: "This is some detail about the item above. We use high-quality materials to ensure satisfaction." }}
            </div>
          </div>
        {% endfor %}
      </div>
    </div>

    <!-- Right: Image -->
    <div class="accordion-image-wrapper">
      {% if section.settings.image != blank %}
        <img src="{{ section.settings.image | image_url: width: 800 }}" alt="{{ section.settings.image.alt | escape }}" loading="lazy">
      {% else %}
        <!-- Mock image block for illustration if no image is selected -->
        <div style="width: 100%; aspect-ratio: 1/1; background-color: #32402C; display:flex; align-items:center; justify-content:center; color:#fff; font-size:1.5rem; border-radius:12px;">Image Placeholder</div>
      {% endif %}
    </div>

  </div>
</div>

<script>
  // Simple vanilla JS to ensure only one accordion opens at a time (optional feature)
  document.querySelectorAll('.section-{{ section.id }}-padding .accordion-item').forEach(item => {
    item.addEventListener('click', function() {
      // If you want exclusive toggling, uncomment below
      /*
      document.querySelectorAll('.section-{{ section.id }}-padding .accordion-item').forEach(other => {
        if(other !== item) other.classList.remove('active');
      });
      */
    });
  });
</script>

{% schema %}
{
  "name": "Product Accordion & Image",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Heading",
      "default": "Soft On Buns.\nStrong On Runs."
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Featured Image"
    },
    {
      "type": "header",
      "content": "Padding"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding Top",
      "default": 36
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding Bottom",
      "default": 36
    }
  ],
  "blocks": [
    {
      "type": "accordion",
      "name": "Accordion Item",
      "settings": [
        {
          "type": "text",
          "id": "heading",
          "label": "Heading",
          "default": "CERTIFIED FLUSHABLE"
        },
        {
          "type": "textarea",
          "id": "content",
          "label": "Content",
          "default": "Our wipes are rigorously tested to ensure they break down safely in plumbing systems."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Product Accordion & Image",
      "blocks": [
        { "type": "accordion", "settings": { "heading": "CERTIFIED FLUSHABLE" } },
        { "type": "accordion", "settings": { "heading": "HYPOALLERGENIC & SENSITIVE" } },
        { "type": "accordion", "settings": { "heading": "PLANT BASED INGREDIENTS" } },
        { "type": "accordion", "settings": { "heading": "RESEALABLE DISPENSER BOX" } },
        { "type": "accordion", "settings": { "heading": "POO~POURRI GUARANTEE" } },
        { "type": "accordion", "settings": { "heading": "SIZE GUIDE" } }
      ]
    }
  ]
}
{% endschema %}
