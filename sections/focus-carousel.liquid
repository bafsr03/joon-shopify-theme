{{ 'component-focus-carousel.css' | asset_url | stylesheet_tag }}

{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
  }
{%- endstyle -%}

<div class="focus-carousel color-{{ section.settings.color_scheme }} gradient section-{{ section.id }}-padding">
  <div class="page-width">

    <div class="focus-carousel__header scroll-trigger animate--slide-in">
      {%- if section.settings.eyebrow != blank -%}
        <p class="focus-carousel__eyebrow">{{ section.settings.eyebrow }}</p>
      {%- endif -%}
      {%- if section.settings.title != blank -%}
        <h2 class="focus-carousel__title">{{ section.settings.title }}</h2>
      {%- endif -%}
    </div>

    <div class="focus-carousel__stage scroll-trigger animate--slide-in">
      <div class="focus-carousel__track-wrapper">
        <div class="focus-carousel__track">
          {%- if section.blocks.size > 0 -%}
            {%- comment -%} Double loop for seamless marquee {%- endcomment -%}
            {%- for i in (1..2) -%}
              {%- for block in section.blocks -%}
                <div class="focus-carousel__item" {{ block.shopify_attributes }}>
                  <div class="focus-carousel__image-wrap">
                    {%- if block.settings.image != blank -%}
                      {{ block.settings.image | image_url: width: 400 | image_tag: loading: 'lazy', alt: block.settings.title }}
                    {%- else -%}
                      {{ 'logo' | placeholder_svg_tag: 'placeholder-svg' }}
                    {%- endif -%}
                  </div>
                </div>
              {%- endfor -%}
            {%- endfor -%}
          {%- else -%}
            {%- for i in (1..15) -%}
              <div class="focus-carousel__item">
                <div class="focus-carousel__image-wrap">
                  {{ 'logo' | placeholder_svg_tag: 'placeholder-svg' }}
                </div>
              </div>
            {%- endfor -%}
          {%- endif -%}
        </div>
      </div>
    </div>

  </div>
</div>

{% schema %}
{
  "name": "Focus Carousel",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow text",
      "default": "TRUSTED BY"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Section title",
      "default": "Enterprise-grade infrastructure trusted by 600K+ customers running AI inference."
    },
    {
      "type": "header",
      "content": "Section padding"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding top",
      "default": 80
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding bottom",
      "default": 80
    }
  ],
  "blocks": [
    {
      "type": "brand",
      "name": "Brand",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Brand image"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Brand name"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Brand collection link"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Focus Carousel",
      "blocks": [
        { "type": "brand" },
        { "type": "brand" },
        { "type": "brand" },
        { "type": "brand" },
        { "type": "brand" },
        { "type": "brand" },
        { "type": "brand" },
        { "type": "brand" }
      ]
    }
  ]
}
{% endschema %}
