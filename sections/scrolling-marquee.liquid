{{ 'component-scrolling-marquee.css' | asset_url | stylesheet_tag }}

{%- liquid
  assign repeat_count = section.settings.repeat_count
  assign speed = section.settings.speed
-%}

{%- style -%}
  .scrolling-marquee--{{ section.id }} {
    {% if section.settings.use_gradient %}
      background: linear-gradient(90deg, #050D06, #182619, #32402C);
      color: #ffffff;
    {% else %}
      background-color: {{ section.settings.background_color }};
    {% endif %}
    --marquee-speed: {{ speed }}s;
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
  }
  {% if section.settings.use_gradient %}
    .scrolling-marquee--{{ section.id }} .scrolling-marquee__text {
      color: #ffffff;
    }
    .scrolling-marquee--{{ section.id }} .scrolling-marquee__separator {
      color: #ffffff;
    }
  {% endif %}
{%- endstyle -%}

<div
  class="scrolling-marquee scrolling-marquee--{{ section.id }} color-{{ section.settings.color_scheme }} scroll-trigger animate--fade-in"
  aria-label="{{ section.settings.text | escape }}"
  role="marquee"
>
  <div class="scrolling-marquee__track" aria-hidden="true">
    {%- comment -%} Two identical passes create a seamless CSS loop {%- endcomment -%}
    {%- for pass in (1..2) -%}
      <div class="scrolling-marquee__inner">
        {%- for i in (1..repeat_count) -%}
          <span class="scrolling-marquee__item">
            <span class="scrolling-marquee__text">
              {%- if section.settings.text != blank -%}
                {{ section.settings.text }}
              {%- else -%}
                {{ 'general.scrolling_marquee.default_text' | t | default: 'BY MERCHANTS  FOR MERCHANTS' }}
              {%- endif -%}
            </span>
            <span class="scrolling-marquee__separator" aria-hidden="true">✦</span>
          </span>
        {%- endfor -%}
      </div>
    {%- endfor -%}
  </div>
  <span class="visually-hidden">
    {%- if section.settings.text != blank -%}
      {{ section.settings.text }}
    {%- else -%}
      {{ 'general.scrolling_marquee.default_text' | t | default: 'BY MERCHANTS  FOR MERCHANTS' }}
    {%- endif -%}
  </span>
</div>

{% schema %}
{
  "name": "Scrolling Marquee",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-3"
    },
    {
      "type": "checkbox",
      "id": "use_gradient",
      "label": "Use vibrant gradient background",
      "default": true
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background colour override",
      "default": "#22c55e"
    },
    {
      "type": "text",
      "id": "text",
      "label": "Marquee text",
      "default": "BY MERCHANTS  FOR MERCHANTS"
    },
    {
      "type": "range",
      "id": "repeat_count",
      "min": 2,
      "max": 10,
      "step": 1,
      "label": "Text repetitions per pass",
      "default": 5
    },
    {
      "type": "range",
      "id": "speed",
      "min": 5,
      "max": 60,
      "step": 5,
      "unit": "s",
      "label": "Scroll speed (lower = faster)",
      "default": 20
    },
    {
      "type": "header",
      "content": "Section padding"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 40,
      "step": 2,
      "unit": "px",
      "label": "Padding top",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 40,
      "step": 2,
      "unit": "px",
      "label": "Padding bottom",
      "default": 0
    }
  ],
  "presets": [
    {
      "name": "Scrolling Marquee"
    }
  ]
}
{% endschema %}
